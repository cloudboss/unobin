factory: {
  inputs: {
    e2e-config: {
      type:    library-config('example.com/unobin/e2elib')
      default: {
        base-dir:       '.'
        event-log-path: 'events.ndjson'
        nested:         { label: 'nested' }
      }
    }
    greeting:     { type: string }
    cluster-name: { type: string }
    size:         { type: integer }
    use-spot:     { type: boolean }
    ratio:        { type: number }
    subnets:      { type: list(string) }
    answer:       { type: string }
    comment:      { type: optional(string) }
    config:       { type: object({ host: string, port: integer }) }
    tags:         { type: list(string) }
    endpoint:     { type: string }
    quoted:       { type: string }
  }

  imports: {
    e2e: 'example.com/unobin/e2elib'
  }

  library-configs: {
    e2e: input.e2e-config
  }

  actions: {
    hi: e2e.echo {
      text: input.greeting
    }
  }

  outputs: {
    said: { value: action.hi.text }
    env: {
      value: {
        greeting: input.greeting
        cluster:  input.cluster-name
        size:     input.size
        use-spot: input.use-spot
        ratio:    input.ratio
        subnets:  input.subnets
        answer:   input.answer
        note:     input.comment ?? 'none'
        config:   input.config
        tags:     input.tags
        endpoint: input.endpoint
        quoted:   input.quoted
      }
    }
  }
}
