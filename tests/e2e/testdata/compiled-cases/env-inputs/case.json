{
  "name": "env-inputs",
  "factoryPath": "src",
  "libraryPath": "example.com/unobin/e2e/env-inputs",
  "build": true,
  "commands": [
    {
      "name": "plan-env",
      "args": ["plan", "--ascii", "-c", "stacks/dev.ub", "-o", "env.ubp"],
      "env": {
        "UB_VAR_answer": "true",
        "UB_VAR_cluster_name": "web-prod",
        "UB_VAR_comment": "42",
        "UB_VAR_config": "{\"host\": \"web\", \"port\": 8080}",
        "UB_VAR_endpoint": "https://example.com/health",
        "UB_VAR_greeting": "from-env",
        "UB_VAR_quoted": "'hello world'",
        "UB_VAR_ratio": "1.5",
        "UB_VAR_size": "5",
        "UB_VAR_subnets": "['subnet-a', 'subnet-b']",
        "UB_VAR_tags": "[\"a\", \"b\"]",
        "UB_VAR_use_spot": "true"
      },
      "stdout": "want/plan-env.stdout",
      "stderr": "want/plan-env.stderr"
    },
    {
      "name": "apply-env",
      "args": ["apply", "--output", "unobin", "env.ubp"],
      "stdout": "want/apply-env.stdout",
      "stderr": "want/apply-env.stderr"
    },
    {
      "name": "output-env-json",
      "args": ["output", "--json", "-c", "stacks/dev.ub"],
      "stdout": "want/output-env.json",
      "stderr": "want/output-env.stderr"
    }
  ],
  "deterministic": true
}
