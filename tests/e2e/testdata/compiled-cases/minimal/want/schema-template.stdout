stack: {
  factory: {
    pin: {
      library-path: 'example.com/unobin/e2e/minimal'
      supported-versions: [
        { version: 'v0.0.0', content-revision: '<revision>' },
      ]
    }
    inputs: {
      e2e-config: null  # type: ?
    }
  }

  state: local {
    path: '.unobin/state'
  }

  encryption: noop {}
}
