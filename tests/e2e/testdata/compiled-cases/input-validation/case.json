{
  "name": "input-validation",
  "factoryPath": "src",
  "libraryPath": "example.com/unobin/e2e/input-validation",
  "build": true,
  "commands": [
    {
      "name": "plan-defaults",
      "args": ["plan", "--ascii", "-c", "stacks/valid/defaults.ub", "-o", "defaults.ubp"],
      "stdout": "want/plan-defaults.stdout",
      "stderr": "want/plan-defaults.stderr"
    },
    {
      "name": "apply-defaults",
      "args": ["apply", "--output", "unobin", "defaults.ubp"],
      "stdout": "want/apply-defaults.stdout",
      "stderr": "want/apply-defaults.stderr"
    },
    {
      "name": "output-defaults",
      "args": ["output", "--json", "-c", "stacks/valid/defaults.ub"],
      "stdout": "want/output-defaults.json",
      "stderr": "want/output-defaults.stderr"
    },
    {
      "name": "plan-nulls",
      "args": ["plan", "--ascii", "-c", "stacks/valid/nulls.ub", "-o", "nulls.ubp"],
      "stdout": "want/plan-nulls.stdout",
      "stderr": "want/plan-nulls.stderr"
    },
    {
      "name": "apply-nulls",
      "args": ["apply", "--output", "unobin", "nulls.ubp"],
      "stdout": "want/apply-nulls.stdout",
      "stderr": "want/apply-nulls.stderr"
    },
    {
      "name": "output-nulls",
      "args": ["output", "--json", "-c", "stacks/valid/nulls.ub"],
      "stdout": "want/output-nulls.json",
      "stderr": "want/output-nulls.stderr"
    },
    {
      "name": "plan-type-mismatch-string",
      "args": ["plan", "--ascii", "-c", "stacks/invalid/type-mismatch-string.ub"],
      "stderr": "want/plan-type-mismatch-string.stderr",
      "exitCode": 1
    },
    {
      "name": "plan-integer-number",
