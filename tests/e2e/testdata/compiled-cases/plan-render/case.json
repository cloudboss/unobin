{
  "name": "plan-render",
  "factoryPath": "src",
  "libraryPath": "example.com/unobin/e2e/plan-render",
  "build": true,
  "commands": [
    {
      "name": "plan-create",
      "args": ["plan", "-c", "stacks/dev.ub", "-o", "create.ubp"],
      "stdout": "want/plan-create.stdout",
      "stderr": "want/plan-create.stderr"
    },
    {
      "name": "apply-create",
      "args": ["apply", "--output", "unobin", "create.ubp"],
      "stdout": "want/apply-create.stdout",
      "stderr": "want/apply-create.stderr"
    },
    {
      "name": "plan-noop",
      "args": ["plan", "-c", "stacks/dev.ub"],
      "stdout": "want/plan-noop.stdout",
      "stderr": "want/plan-noop.stderr"
    }
  ],
  "deterministic": true
}
