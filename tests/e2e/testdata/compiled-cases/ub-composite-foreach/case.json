{
  "name": "ub-composite-foreach",
  "factoryPath": "src",
  "libraryPath": "example.com/unobin/e2e/ub-composite-foreach",
  "build": true,
  "commands": [
    {
      "name": "print-graph",
      "args": ["print-graph"],
      "stdout": "want/print-graph.stdout",
      "stderr": "want/print-graph.stderr"
    },
    {
      "name": "validate",
      "args": ["validate", "-c", "stacks/dev/dev.ub"],
      "stdout": "want/validate.stdout",
      "stderr": "want/validate.stderr"
    },
    {
      "name": "plan",
      "args": ["plan", "--ascii", "-c", "stacks/dev/dev.ub", "-o", "plan.ubp"],
      "stdout": "want/plan.stdout",
      "stderr": "want/plan.stderr"
    },
    {
      "name": "apply",
      "args": ["apply", "--output", "unobin", "plan.ubp"],
      "stdout": "want/apply.stdout",
      "stderr": "want/apply.stderr"
    },
    {
      "name": "output",
      "args": ["output", "--json", "-c", "stacks/dev/dev.ub"],
      "stdout": "want/output.json",
      "stderr": "want/output.stderr"
    }
  ],
  "files": [
    { "path": "events.ndjson", "want": "want/events.ndjson" }
  ],
  "stateSummary": "want/state-summary.json",
  "deterministic": true
}
