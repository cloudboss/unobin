factory: {
  inputs: {
    e2e-config: {
      type: library-config('example.com/unobin/e2elib')
      default: {
        base-dir:       '.'
        event-log-path: 'events.ndjson'
        nested:         { label: 'nested' }
      }
    }
  }

  imports: {
    e2e:     'example.com/unobin/e2elib'
    greeter: './libraries/greeter'
  }

  library-configs: {
    e2e: var.e2e-config
  }

  resources: {
    hello: greeter.greeting {
      path:       'files/hello.txt'
      content:    'hello'
      e2e-config: var.e2e-config
    }

    other: e2e.file {
      path:    'files/other.txt'
      content: 'other'
    }
  }
}
