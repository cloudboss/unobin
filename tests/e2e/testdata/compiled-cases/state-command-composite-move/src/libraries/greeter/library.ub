greeting: resource {
  inputs: {
    path:       { type: string }
    content:    { type: string }
    e2e-config: { type: library-config('example.com/unobin/e2elib') }
  }

  imports: {
    e2e: 'example.com/unobin/e2elib'
  }

  library-configs: {
    e2e: input.e2e-config
  }

  resources: {
    this: e2e.file {
      path:    input.path
      content: input.content
    }
  }

  outputs: {
    path: { value: resource.this.path }
  }
}
