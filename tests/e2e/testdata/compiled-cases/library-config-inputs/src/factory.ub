factory: {
  inputs: {
    e2e-config: {
      type: library-config('example.com/unobin/e2elib')
      default: {
        base-dir:       '.'
        event-log-path: 'events.ndjson'
        prefix:         'default-'
        nested:         { label: 'nested' }
      }
    }
    size: { type: integer, default: 3 }
  }

  imports: {
    e2e: 'example.com/unobin/e2elib'
  }

  library-configs: {
    e2e: input.e2e-config
  }

  actions: {
    hi: e2e.echo {
      text: 'hello'
    }
  }

  outputs: {
    prefixed: { value: action.hi.prefixed }
    size:     { value: input.size }
  }
}
