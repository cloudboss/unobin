archive: resource {
  inputs: {
    path: { type: string }
    body: { type: string }
    e2e-config: { type: library-config('example.com/unobin/e2elib') }
  }

  imports: {
    e2e: 'example.com/unobin/e2elib'
  }

  library-configs: {
    e2e: var.e2e-config
  }

  resources: {
    member: e2e.file {
      path:    var.path
      content: var.body
    }
  }

  outputs: {
    path:    { value: resource.member.path }
    content: { value: resource.member.content }
  }
}
