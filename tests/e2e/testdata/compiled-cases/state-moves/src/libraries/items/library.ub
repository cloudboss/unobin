item: resource {
  state-moves: [
    { from: 'resource.old-file', to: 'resource.file' },
  ]

  inputs: {
    path: { type: string }
    content: { type: string }
    e2e-config: { type: library-config('example.com/unobin/e2elib') }
  }

  imports: {
    e2e: 'example.com/unobin/e2elib'
  }

  library-configs: {
    e2e: input.e2e-config
  }

  resources: {
    file: e2e.file {
      path:    input.path
      content: input.content
    }
  }

  outputs: {
    content: { value: resource.file.content }
    path:    { value: resource.file.path }
  }
}
