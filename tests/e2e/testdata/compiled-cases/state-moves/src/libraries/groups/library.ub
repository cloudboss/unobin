group: resource {
  state-moves: [
    { from: 'e2e.file@resource.old-file', to: 'e2e.file@resource.file' },
    { from: 'items.item@resource.old-single', to: 'items.item@resource.single' },
  ]

  inputs: {
    file-path: { type: string }
    single-path: { type: string }
    content: { type: string }
    e2e-config: { type: library-config('example.com/unobin/e2elib') }
  }

  imports: {
    e2e:   'example.com/unobin/e2elib'
    items: '../items'
  }

  library-configs: {
    e2e: var.e2e-config
  }

  resources: {
    file: e2e.file {
      path:    var.file-path
      content: var.content
    }

    single: items.item {
      path:       var.single-path
      content:    var.content
      e2e-config: var.e2e-config
    }
  }

  outputs: {
    file-content:   { value: resource.file.content }
    single-content: { value: resource.single.content }
  }
}
