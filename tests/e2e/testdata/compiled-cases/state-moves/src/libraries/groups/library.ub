group: resource {
  state-moves: [
    { from: resource.old-file, to: resource.file },
    { from: resource.old-single, to: resource.single },
  ]

  inputs: {
    file-path: { type: string }
    single-path: { type: string }
    content: { type: string }
    e2e-config: { type: library-config('example.com/unobin/e2elib') }
  }

  imports: {
    e2e:   'example.com/unobin/e2elib'
    items: '../items'
  }

  library-configs: {
    e2e: input.e2e-config
  }

  resources: {
    file: e2e.file {
      path:    input.file-path
      content: input.content
    }

    single: items.item {
      path:       input.single-path
      content:    input.content
      e2e-config: input.e2e-config
    }
  }

  outputs: {
    file-content:   { value: resource.file.content }
    single-content: { value: resource.single.content }
  }
}
