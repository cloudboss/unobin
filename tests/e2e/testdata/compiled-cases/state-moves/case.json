{
  "name": "state-moves",
  "factoryPath": "src",
  "libraryPath": "example.com/unobin/e2e/state-moves",
  "build": true,
  "stateSeed": "seed/state.json",
  "commands": [
    {
      "name": "validate",
      "args": ["validate", "-c", "stacks/dev/dev.ub"],
      "stdout": "want/validate.stdout",
      "stderr": "want/validate.stderr"
    },
    {
      "name": "plan",
      "args": ["plan", "--ascii", "-c", "stacks/dev/dev.ub", "-o", "move.ubp"],
      "stdout": "want/plan.stdout",
      "stderr": "want/plan.stderr"
    },
    {
      "name": "apply",
      "args": ["apply", "--output", "unobin", "move.ubp"],
      "stdout": "want/apply.stdout",
      "stderr": "want/apply.stderr",
      "exitCode": 1
    }
  ],
  "stateSummary": "want/state-summary.json",
  "deterministic": true
}
