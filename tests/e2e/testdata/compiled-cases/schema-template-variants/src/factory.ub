factory: {
  inputs: {
    greeting: {
      type:        string
      description: 'Text to write'
    }
    count:   { type: integer }
    enabled: { type: boolean }
    tags:    { type: list(string) }
  }

  outputs: {
    endpoint: { value: var.greeting, description: 'Public endpoint URL' }
    token:    { value: var.greeting, @sensitive: true }
    plain:    { value: var.greeting }
  }
}
