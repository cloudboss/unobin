factory: {
  inputs: {
    e2e-config: {
      type: library-config('example.com/unobin/e2elib')
      default: {
        base-dir:       '.'
        event-log-path: 'events.ndjson'
        nested:         { label: 'nested' }
      }
    }
    name:   { type: string }
    secret: { type: string, @sensitive: true }
  }

  imports: {
    e2e: 'example.com/unobin/e2elib'
  }

  library-configs: {
    e2e: input.e2e-config
  }

  locals: {
    name-copy:     input.name
    secret-copy:   input.secret
    secret-chain:  local.secret-copy
    secret-output: action.go-secret.value
  }

  actions: {
    record: e2e.record {
      name:    input.name
      message: input.secret
    }

    go-secret: e2e.secret {
      label: input.name
      value: input.secret
    }

    record-local: e2e.record {
      name:    local.name-copy
      message: local.secret-chain
    }

    record-output-local: e2e.record {
      name:    'output-local'
      message: local.secret-output
    }
  }

  outputs: {
    public-name:   { value: action.record.name }
    token:         { value: action.record.record, @sensitive: true }
    library-token: { value: action.go-secret.value }
  }
}
