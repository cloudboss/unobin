{
  "format-version": 1,
  "factory": {
    "name": "sensitivity",
    "version": "v0.0.0",
    "content-revision": "<revision>"
  },
  "stack": "dev",
  "entries": [
    {
      "address": "action.go-secret",
      "entry-kind": "action",
      "category": "action",
      "binding": {
        "alias": "e2e",
        "library-path": "example.com/unobin/e2elib",
        "kind": "secret"
      },
      "sensitive-inputs": [
        "value"
      ],
      "sensitive-outputs": [
        "value"
      ],
      "inputs": {
        "label": "deploy",
        "value": "top-secret"
      },
      "outputs": {
        "label": "deploy",
        "value": "top-secret"
      }
    },
    {
      "address": "action.record",
      "entry-kind": "action",
      "category": "action",
      "binding": {
        "alias": "e2e",
        "library-path": "example.com/unobin/e2elib",
        "kind": "record"
      },
      "sensitive-inputs": [
        "message"
      ],
      "inputs": {
        "message": "top-secret",
        "name": "deploy"
      },
      "outputs": {
        "count": 1,
        "name": "deploy",
        "record": "deploy:top-secret"
      }
    },
    {
      "address": "action.record-local",
      "entry-kind": "action",
      "category": "action",
      "binding": {
        "alias": "e2e",
        "library-path": "example.com/unobin/e2elib",
        "kind": "record"
      },
      "sensitive-inputs": [
        "message"
      ],
      "inputs": {
        "message": "top-secret",
        "name": "deploy"
      },
      "outputs": {
        "count": 1,
        "name": "deploy",
        "record": "deploy:top-secret"
      }
    },
    {
      "address": "action.record-output-local",
      "entry-kind": "action",
      "category": "action",
      "binding": {
        "alias": "e2e",
        "library-path": "example.com/unobin/e2elib",
        "kind": "record"
      },
      "sensitive-inputs": [
        "message"
      ],
      "inputs": {
        "message": "top-secret",
        "name": "output-local"
      },
      "outputs": {
        "count": 1,
        "name": "output-local",
        "record": "output-local:top-secret"
      },
      "depends-on": [
        "action.go-secret"
      ]
    }
  ],
  "outputs": {
    "library-token": "top-secret",
    "public-name": "deploy",
    "token": "deploy:top-secret"
  }
}
