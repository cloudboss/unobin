factory: {
  inputs: {
    file-content: { type: string }
    e2e-config: {
      type: library-config('example.com/unobin/e2elib')
      default: {
        base-dir:       '.'
        event-log-path: 'events.ndjson'
        nested:         { label: 'nested' }
      }
    }
  }

  imports: {
    e2e: 'example.com/unobin/e2elib'
  }

  library-configs: {
    e2e: input.e2e-config
  }

  resources: {
    doc: e2e.file {
      path:    'files/data.txt'
      content: input.file-content
    }
  }

  data-sources: {
    read-back: e2e.read-file {
      path: resource.doc.path
    }
  }

  actions: {
    capture: e2e.record {
      name:    'read'
      message: data-source.read-back.content
    }
  }

  outputs: {
    read-content: { value: data-source.read-back.content }
    read-size:    { value: data-source.read-back.size }
    recorded:     { value: action.capture.record }
  }
}
