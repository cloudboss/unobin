{
  "name": "plan-parallelism",
  "factoryPath": "src",
  "libraryPath": "example.com/unobin/e2e/plan-parallelism",
  "build": true,
  "commands": [
    {
      "name": "plan-config-parallelism",
      "args": ["plan", "--ascii", "-c", "stacks/dev.ub", "-o", "config.ubp"],
      "stdout": "want/plan-config-parallelism.stdout",
      "stderr": "want/plan-config-parallelism.stderr"
    },
    {
      "name": "plan-flag-parallelism",
      "args": ["plan", "--ascii", "-c", "stacks/dev.ub", "-o", "flag.ubp", "--parallelism", "7"],
      "stdout": "want/plan-flag-parallelism.stdout",
      "stderr": "want/plan-flag-parallelism.stderr"
    },
    {
      "name": "plan-zero-parallelism",
      "args": [
        "plan",
        "--allow-version-mismatch",
        "--ascii",
        "-c",
        "stacks/zero.ub",
        "-o",
        "zero.ubp"
      ],
      "stderr": "want/plan-zero-parallelism.stderr",
      "exitCode": 1,
      "skipPin": true
    },
    {
      "name": "plan-non-integer-parallelism",
      "args": [
        "plan",
        "--allow-version-mismatch",
        "--ascii",
        "-c",
        "stacks/non-integer.ub",
        "-o",
        "non-integer.ubp"
      ],
      "stderr": "want/plan-non-integer-parallelism.stderr",
      "exitCode": 1,
      "skipPin": true
    }
  ],
  "planSummaries": [
    { "path": "config.ubp", "want": "want/config-plan-summary.json" },
    { "path": "flag.ubp", "want": "want/flag-plan-summary.json" }
  ],
  "planEnvelopes": [
    { "path": "config.ubp", "want": "want/config-plan-envelope.json" }
  ],
  "deterministic": true
}
