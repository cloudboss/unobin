#!/usr/bin/env python3
import json
import os
import sys
import urllib.request


def read_frames(url):
    with urllib.request.urlopen(url + "events", timeout=15) as resp:
        for raw in resp:
            line = raw.decode("utf-8").rstrip("\n")
            if not line.startswith("data: "):
                continue
            frame = json.loads(line[6:])
            yield frame
            if frame.get("kind") == "run-complete":
                return


def main():
    if len(sys.argv) != 2:
        raise SystemExit("usage: capture-run-view URL")
    out = os.environ["RUN_VIEW_GRAPH"]
    graph = None
    for frame in read_frames(sys.argv[1]):
        if frame.get("kind") == "graph":
            graph = frame
    if graph is None:
        raise SystemExit("no graph frame")
    graph["seq"] = "<seq>"
    with open(out, "w", encoding="utf-8") as f:
        json.dump(graph, f, indent=2, sort_keys=True)
        f.write("\n")


if __name__ == "__main__":
    main()
