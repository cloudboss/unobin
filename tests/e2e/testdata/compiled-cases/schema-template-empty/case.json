{
  "name": "schema-template-empty",
  "factoryPath": "src",
  "build": true,
  "commands": [
    {
      "name": "schema-template",
      "args": ["schema", "template"],
      "stdout": "want/schema-template.stdout",
      "stderr": "want/schema-template.stderr"
    },
    {
      "name": "schema-show",
      "args": ["schema", "show"],
      "stdout": "want/schema-show.stdout",
      "stderr": "want/schema-show.stderr"
    }
  ]
}
