factory: {
  inputs: {
    e2e-config: {
      type: library-config('example.com/unobin/e2elib')
      default: {
        base-dir:       '.'
        event-log-path: 'events.ndjson'
        nested:         { label: 'nested' }
      }
    }
  }

  imports: {
    e2e:     'example.com/unobin/e2elib'
    greeter: './libraries/greeter'
  }

  library-configs: { e2e: input.e2e-config }

  resources: {
    x: greeter.greeting { message: 'hi', e2e-config: input.e2e-config }
  }
}
