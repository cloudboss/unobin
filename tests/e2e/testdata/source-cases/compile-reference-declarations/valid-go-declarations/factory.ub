factory: {
  inputs: {
    e2e-config: {
      type: library-config('example.com/unobin/e2elib')
      default: {
        base-dir:       '.'
        event-log-path: 'events.ndjson'
        nested:         { label: 'nested' }
      }
    }
  }

  imports: {
    e2e: 'example.com/unobin/e2elib'
  }

  library-configs: { e2e: input.e2e-config }

  resources: {
    doc: e2e.file { path: 'files/doc.txt', content: 'hello' }
  }

  data-sources: {
    prior: e2e.read-file { path: 'files/doc.txt', optional: true }
  }

  actions: {
    say: e2e.echo { text: 'hello' }
  }
}
