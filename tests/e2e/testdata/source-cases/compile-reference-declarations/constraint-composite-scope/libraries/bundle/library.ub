thing: resource {
  inputs: {
    region: { type: string }
    e2e-config: { type: library-config('example.com/unobin/e2elib') }
  }

  constraints: [{ kind: predicate, when: input.bogus == 'x', require: input.region == 'y' }]

  imports: { e2e: 'example.com/unobin/e2elib' }

  library-configs: { e2e: input.e2e-config }

  resources: {
    one: e2e.file { path: input.region, content: 'hi' }
  }

  outputs: { path: { value: resource.one.path } }
}
