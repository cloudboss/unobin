factory: {
  inputs: {
    e2e-config: {
      type: library-config('example.com/unobin/e2elib')
      default: {
        base-dir:       '.'
        event-log-path: 'events.ndjson'
        nested:         { label: 'nested' }
      }
    }
  }

  imports: {
    e2e: 'example.com/unobin/e2elib'
    bundle: './libraries/bundle'
  }

  library-configs: { e2e: var.e2e-config }

  resources: {
    demo: bundle.file-pair { path: 'files/demo.txt', e2e-config: var.e2e-config }
  }

  outputs: { path: { value: resource.demo.path } }
}
