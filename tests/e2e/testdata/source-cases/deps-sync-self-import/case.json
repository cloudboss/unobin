{
  "name": "deps-sync-self-import",
  "rootPath": "root",
  "executor": "root",
  "commands": [
    {
      "name": "deps-sync",
      "args": ["deps", "sync", "-p", "factory.ub"],
      "stderr": "want/deps-sync.stderr"
    }
  ],
  "files": [
    { "path": "root/manifest.ub", "want": "want/manifest.ub" },
    { "path": "root/lock.ub", "want": "want/lock.ub" }
  ]
}
