factory: {
  inputs: {
    tags: { type: map(string) }

    e2e-config: {
      type: library-config('example.com/unobin/e2elib')
      default: {
        base-dir:       '.'
        event-log-path: 'events.ndjson'
        nested:         { label: 'nested' }
      }
    }
  }

  imports: { e2e: 'example.com/unobin/e2elib' }

  library-configs: { e2e: input.e2e-config }

  resources: {
    one: e2e.file {
      @for-each: input.tags
      path:      @each.value
      content:   'hello'
    }
  }
}
