factory: {
  inputs: {
    e2e-config: {
      type: library-config('example.com/unobin/e2elib')
      default: {
        base-dir:       '.'
        event-log-path: 'events.ndjson'
        nested:         { label: 'nested' }
      }
    }
  }

  locals: { limit: 3 }

  imports: { e2e: 'example.com/unobin/e2elib' }

  library-configs: { e2e: input.e2e-config }

  resources: {
    x: e2e.file { path: 'files/x.txt', content: 'a' }
  }

  constraints: [
    { kind: predicate, when: true, require: resource.x.path != null },
    { kind: predicate, when: true, require: local.limit > 0 },
  ]
}
