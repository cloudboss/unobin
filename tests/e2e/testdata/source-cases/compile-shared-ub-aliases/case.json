{
  "name": "compile-shared-ub-aliases",
  "rootPath": "demo-factory",
  "executor": "root",
  "cliVersion": "v0.1.0",
  "remotes": [
    {
      "key": "github.com/example/shared//ub/shared@v1",
      "path": "remotes/shared",
      "commit": "shared"
    },
    {
      "key": "github.com/example/wrap//ub/wrap@v1",
      "path": "remotes/wrap",
      "commit": "wrap"
    }
  ],
  "commands": [
    {
      "name": "compile",
      "args": ["compile", "-p", "factory.ub", "-o", "build"],
      "stderr": "want/compile.stderr"
    }
  ],
  "files": [
    { "path": "demo-factory/build/main.go", "want": "want/main.go" },
    { "path": "demo-factory/build/internal/wrap/wrap.go", "want": "want/wrap.go" }
  ],
  "absentFiles": ["demo-factory/build/internal/inside"]
}
