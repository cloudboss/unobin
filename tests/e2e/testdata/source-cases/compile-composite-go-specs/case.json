{
  "name": "compile-composite-go-specs",
  "rootPath": "demo-factory",
  "executor": "root",
  "cliVersion": "v0.1.0",
  "commands": [
    {
      "name": "compile",
      "args": ["compile", "-p", "factory.ub", "-o", "build"],
      "stderr": "want/compile.stderr"
    }
  ],
  "files": [
    { "path": "demo-factory/build/main.go", "want": "want/main.go" },
    { "path": "demo-factory/build/go.mod", "want": "want/go.mod" },
    { "path": "demo-factory/build/internal/files/files.go", "want": "want/files.go" }
  ]
}
