factory: {
  inputs: {
    path: { type: string }
    e2e-config: {
      type: library-config('example.com/unobin/e2elib')
      default: {
        base-dir:       '.'
        event-log-path: 'events.ndjson'
        nested:         { label: 'nested' }
      }
    }
  }

  locals: {
    base:    input.path
    derived: local.base
  }

  imports: { e2e: 'example.com/unobin/e2elib' }

  library-configs: { e2e: input.e2e-config }

  resources: {
    one: e2e.file {
      path:    local.derived
      content: 'hello'
    }
  }

  outputs: { p: { value: local.derived } }
}
