factory: {
  inputs: {
    e2e-config: {
      type: library-config('example.com/unobin/e2elib')
      default: {
        base-dir:       '.'
        event-log-path: 'events.ndjson'
        nested:         { label: 'nested' }
      }
    }
  }

  imports: { e2e: 'example.com/unobin/e2elib' }

  library-configs: { e2e: input.e2e-config }

  state-moves: [
    { from: resource.old, to: resource.missing },
  ]

  resources: {
    new: e2e.file {
      path:    'files/new.txt'
      content: 'new'
    }
  }
}
