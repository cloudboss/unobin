factory: {
  inputs: {
    e2e-config: {
      type: library-config('example.com/unobin/e2elib')
      default: {
        base-dir:       '.'
        event-log-path: 'events.ndjson'
        nested:         { label: 'nested' }
      }
    }
  }

  imports: {
    e2e:    'example.com/unobin/e2elib'
    badnet: './libraries/badnet'
  }

  library-configs: { e2e: var.e2e-config }

  resources: {
    app: badnet.web-cluster { e2e-config: var.e2e-config }
  }
}
