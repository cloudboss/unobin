{
  "name": "compile-replace-go-module-no-project-lock",
  "rootPath": "demo-factory",
  "executor": "root",
  "cliVersion": "v0.1.0",
  "commands": [
    {
      "name": "compile",
      "args": [
        "compile",
        "-p",
        "factory.ub",
        "-o",
        "-",
        "--replace-go-module",
        "github.com/x/cloud=$WORKSPACE/cloud"
      ],
      "stdout": "want/compile.stdout",
      "stderr": "want/compile.stderr"
    }
  ]
}
