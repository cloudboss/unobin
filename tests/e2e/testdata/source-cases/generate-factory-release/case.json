{
  "name": "generate-factory-release",
  "rootPath": ".",
  "executor": "root",
  "cliVersion": "v0.3.0",
  "commands": [
    {
      "name": "generate-factory",
      "args": ["generate", "factory", "-o", "generated"],
      "stdout": "want/stdout",
