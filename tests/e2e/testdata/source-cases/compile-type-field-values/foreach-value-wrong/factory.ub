factory: {
  inputs: {
    counts: { type: map(integer) }
    e2e-config: {
      type: library-config('example.com/unobin/e2elib')
      default: {
        base-dir:       '.'
        event-log-path: 'events.ndjson'
        nested:         { label: 'nested' }
      }
    }
  }

  imports: { e2e: 'example.com/unobin/e2elib' }

  library-configs: { e2e: input.e2e-config }

  resources: {
    many: e2e.file { @for-each: input.counts, path: @each.value, content: 'hi' }
  }
}
