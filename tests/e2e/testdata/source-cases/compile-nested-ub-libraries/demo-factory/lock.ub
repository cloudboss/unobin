lock: {
  version:   1
  toolchain: { unobin-version: 'dev' }
  deps: {
    'github.com/example/outer//ub/outer': {
      kind:    go
      version: 'v1'
      commit:  'outer-commit'
    }
    'github.com/example/inner//ub/inner': {
      kind:    go
      version: 'v1'
      commit:  'inner-commit'
    }
    'github.com/cloudboss/unobin-library-std': {
      kind:    go
      version: 'v0.1.0'
      commit:  'std-commit'
    }
  }
}
