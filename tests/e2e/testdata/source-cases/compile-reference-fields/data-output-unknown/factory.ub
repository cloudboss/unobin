factory: {
  inputs: {
    e2e-config: {
      type: library-config('example.com/unobin/e2elib')
      default: {
        base-dir:       '.'
        event-log-path: 'events.ndjson'
        nested:         { label: 'nested' }
      }
    }
  }

  imports: { e2e: 'example.com/unobin/e2elib' }

  library-configs: { e2e: var.e2e-config }

  data: {
    doc: e2e.read-file { path: 'files/missing.txt', optional: true }
  }

  outputs: { bad: { value: data.doc.nope } }
}
