factory: {
  inputs: {
    e2e-config: {
      type: library-config('example.com/unobin/e2elib')
      default: {
        base-dir:       '.'
        event-log-path: 'events.ndjson'
        nested:         { label: 'nested' }
      }
    }
  }

  imports: {
    e2e:    'example.com/unobin/e2elib'
    bundle: './libraries/bundle'
  }

  library-configs: { e2e: input.e2e-config }

  resources: {
    demo: bundle.thing { e2e-config: input.e2e-config }
  }

  outputs: {
    ok:  { value: resource.demo.path }
    bad: { value: resource.demo.bogus }
  }
}
