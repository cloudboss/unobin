web: resource {
  state-moves: [
    { from: 'resource.old', to: 'resource.child/resource.new' },
  ]

  inputs: {
    e2e-config: { type: library-config('example.com/unobin/e2elib') }
  }

  imports: {
    e2e:   'example.com/unobin/e2elib'
    inner: '../inner'
  }

  library-configs: { e2e: var.e2e-config }

  resources: {
    child: inner.cluster { e2e-config: var.e2e-config }
  }
}
