web: resource {
  state-moves: [
    { from: resource.old-child, to: resource.child },
  ]

  inputs: {
    e2e-config: { type: library-config('example.com/unobin/e2elib') }
  }

  imports: {
    e2e:   'example.com/unobin/e2elib'
    inner: '../inner'
  }

  library-configs: { e2e: input.e2e-config }

  resources: {
    child: inner.cluster { e2e-config: input.e2e-config }
  }
}
