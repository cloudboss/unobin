web-cluster: resource {
  state-moves: [
    { from: resource.old, to: resource.new },
  ]

  inputs: {
    e2e-config: { type: library-config('example.com/unobin/e2elib') }
  }

  imports: { e2e: 'example.com/unobin/e2elib' }

  library-configs: { e2e: input.e2e-config }

  resources: {
    new: e2e.file {
      path:    'files/composite.txt'
      content: 'composite'
    }
  }
}
