factory: {
  inputs: {
    e2e-config: {
      type: library-config('example.com/unobin/e2elib')
      default: {
        base-dir:       '.'
        event-log-path: 'events.ndjson'
        nested:         { label: 'nested' }
      }
    }
  }

  imports: { e2e: 'example.com/unobin/e2elib' }

  library-configs: { e2e: var.e2e-config }

  state-moves: [
    { from: 'e2e.file@resource.old', to: 'e2e.file@resource.middle' },
    { from: 'e2e.file@resource.middle', to: 'e2e.file@resource.new' },
  ]

  resources: {
    new: e2e.file {
      path:    'files/new.txt'
      content: 'new'
    }
  }
}
