{
  "name": "deps-sync-skip-nested-project",
  "rootPath": "root",
  "executor": "root",
  "remotes": [
    {
      "key": "example.com/shared@v1.0.0",
      "path": "remotes/shared",
      "commit": "shared"
    },
    {
      "key": "example.com/shared//lib@v1.0.0",
      "path": "remotes/shared/lib",
      "commit": "shared"
    }
  ],
  "commands": [
    {
      "name": "deps-sync",
      "args": ["deps", "sync"],
      "stderr": "want/deps-sync.stderr"
    }
  ],
  "files": [
    { "path": "root/manifest.ub", "want": "want/manifest.ub" },
    { "path": "root/lock.ub", "want": "want/lock.ub" }
  ],
  "absentFiles": ["root/library-c/lock.ub"]
}
