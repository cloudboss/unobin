factory: {
  inputs: {
    files: { type: map(string) }
    e2e-config: {
      type: library-config('example.com/unobin/e2elib')
      default: {
        base-dir:       '.'
        event-log-path: 'events.ndjson'
        nested:         { label: 'nested' }
      }
    }
  }

  imports: { e2e: 'example.com/unobin/e2elib' }

  library-configs: { e2e: var.e2e-config }

  resources: {
    many: e2e.file {
      @for-each: var.files
      path:      @each.key
      content:   @each.value
    }

    mirror: e2e.file {
      @for-each: var.files
      path:      resource.many[@each.key].path
      content:   @each.value
    }
  }
}
