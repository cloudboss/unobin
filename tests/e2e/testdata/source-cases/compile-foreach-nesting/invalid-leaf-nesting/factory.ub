factory: {
  inputs: {
    e2e-config: {
      type: library-config('example.com/unobin/e2elib')
      default: {
        base-dir:       '.'
        event-log-path: 'events.ndjson'
        nested:         { label: 'nested' }
      }
    }
  }

  imports: {
    e2e:   'example.com/unobin/e2elib'
    outer: './libraries/outer'
  }

  library-configs: { e2e: var.e2e-config }

  resources: {
    app: outer.outer {
      @for-each:  { a: 'one' }
      tags:       { t1: 'files/one.txt' }
      e2e-config: var.e2e-config
    }
  }
}
