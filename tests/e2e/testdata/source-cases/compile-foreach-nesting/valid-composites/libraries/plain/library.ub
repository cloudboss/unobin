plain: resource {
  inputs: {
    tags: { type: map(string) }
    e2e-config: { type: library-config('example.com/unobin/e2elib') }
  }

  imports: { e2e: 'example.com/unobin/e2elib' }

  library-configs: { e2e: input.e2e-config }

  resources: {
    it: e2e.file {
      @for-each: input.tags
      path:      @each.value
      content:   @each.value
    }
  }
}
