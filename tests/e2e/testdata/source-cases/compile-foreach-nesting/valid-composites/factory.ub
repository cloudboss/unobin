factory: {
  inputs: {
    e2e-config: {
      type: library-config('example.com/unobin/e2elib')
      default: {
        base-dir:       '.'
        event-log-path: 'events.ndjson'
        nested:         { label: 'nested' }
      }
    }
  }

  imports: {
    e2e:   'example.com/unobin/e2elib'
    slice: './libraries/slice'
    plain: './libraries/plain'
  }

  library-configs: { e2e: input.e2e-config }

  resources: {
    each-slice: slice.slice {
      @for-each:  { a: 'files/a.txt' }
      tag:        @each.value
      e2e-config: input.e2e-config
    }

    plain: plain.plain {
      tags:       { t1: 'files/plain.txt' }
      e2e-config: input.e2e-config
    }
  }
}
