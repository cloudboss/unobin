{
  "name": "deps-clean",
  "rootPath": "root",
  "executor": "root",
  "commands": [
    {
      "name": "deps-clean",
      "args": ["deps", "clean"],
      "env": { "UNOBIN_CACHE_ROOT": "$WORKSPACE/cache/unobin" },
      "stderr": "want/deps-clean.stderr"
    }
  ],
  "absentFiles": ["cache/unobin/imports"]
}
