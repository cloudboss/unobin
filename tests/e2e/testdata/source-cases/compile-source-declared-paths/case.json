{
  "name": "compile-source-declared-paths",
  "rootPath": "demo-factory",
  "executor": "root",
  "cliVersion": "v0.1.0",
  "remotes": [
    {
      "key": "github.com/cloudboss/unobin/pkg/libraries/core@v0.1.0",
      "path": "remotes/core",
      "commit": "c"
    },
    {
      "key": "github.com/cloudboss/unobin/pkg/libraries/core@c",
      "path": "remotes/core",
      "commit": "c"
    }
  ],
  "commands": [
    {
      "name": "compile-file",
      "args": ["compile", "-p", "factory.ub", "-o", "-"],
      "stdout": "want/compile-file.stdout"
    },
    {
      "name": "compile-directory",
      "args": ["compile", "-p", ".", "-o", "-"],
      "stdout": "want/compile-directory.stdout"
    },
    {
      "name": "compile-default",
      "args": ["compile", "-o", "-"],
      "stdout": "want/compile-default.stdout"
    }
  ]
}
