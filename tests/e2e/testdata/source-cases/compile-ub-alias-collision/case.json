    {
      "path": "demo-factory/build/internal/a_a6595328/a_a6595328.go",
      "want": "want/a_a6595328.go"
    },
    { "path": "demo-factory/build/internal/wrap/wrap.go", "want": "want/wrap.go" }
  ]
}
