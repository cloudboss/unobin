{
  "name": "unobin-vscode",
  "displayName": "Unobin",
  "description": "Unobin language support",
  "version": "0.1.0",
  "publisher": "cloudboss",
  "license": "MIT",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:unobin",
    "onCommand:unobin.restartLanguageServer"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "compile": "tsc -p ./",
    "check": "tsc -p ./ --noEmit",
    "vscode:prepublish": "npm run compile"
  },
  "contributes": {
    "languages": [
      {
        "id": "unobin",
        "aliases": [
          "Unobin",
          "unobin"
        ],
        "extensions": [
          ".ub"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "unobin",
        "scopeName": "source.unobin",
        "path": "./syntaxes/unobin.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Unobin",
      "properties": {
        "unobin.path": {
          "type": "string",
          "default": "unobin",
          "description": "Path to the unobin executable."
        }
      }
    },
    "commands": [
      {
        "command": "unobin.restartLanguageServer",
        "title": "Unobin: Restart Language Server"
      }
    ]
  },
  "dependencies": {
    "vscode-languageclient": "10.0.1"
  },
  "devDependencies": {
    "@types/node": "22.10.1",
    "@types/vscode": "1.95.0",
    "typescript": "5.8.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cloudboss/unobin.git",
    "directory": "editors/vscode"
  },
  "bugs": {
    "url": "https://github.com/cloudboss/unobin/issues"
  },
  "keywords": [
    "unobin",
    "language-server",
    "lsp",
    "tree-sitter"
  ],
  "files": [
    "out",
    "src",
    "syntaxes",
    "language-configuration.json",
    "README.md",
    "package.json"
  ]
}
