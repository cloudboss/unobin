(require 'treesit)

(defun unobin-test-checkout-recipe (expected-dir)
  (let* ((recipe (unobin-ts-mode--grammar-recipe))
         (source (nth 1 recipe)))
    (unless (equal source expected-dir)
      (error "expected local grammar source, got %S" recipe))))

(defun unobin-test-face-at (needle index face)
  (goto-char (point-min))
  (unless (search-forward needle nil t)
    (error "missing %s" needle))
  (let ((got (get-text-property (+ (match-beginning 0) index) 'face)))
    (unless (or (eq got face) (and (listp got) (memq face got)))
      (error "expected %S on %s at %d, got %S" face needle index got))))

(defun unobin-test-fallback-queries-compile (grammar-dir mode-path)
  (add-to-list 'treesit-extra-load-path grammar-dir)
  (load-file mode-path)
  (treesit-query-compile
   'unobin (unobin-ts-mode--emacs-query unobin-ts-mode--fallback-highlights))
  (treesit-query-compile 'unobin (unobin-ts-mode--field-keyword-query))
  (treesit-query-compile 'unobin (unobin-ts-mode--reference-root-query)))

(defun unobin-test-fontify (grammar-dir mode-path sample-path)
  (add-to-list 'treesit-extra-load-path grammar-dir)
  (load-file mode-path)
  (with-temp-buffer
    (insert-file-contents sample-path)
    (setq buffer-file-name sample-path)
    (unobin-ts-mode)
    (font-lock-ensure)
    (dolist (check '(("highlight sample" 0 font-lock-comment-face)
                     ("factory" 0 font-lock-keyword-face)
                     ("inputs" 0 font-lock-keyword-face)
                     ("type" 0 font-lock-property-name-face)
                     ("string" 0 font-lock-type-face)
                     ("optional" 0 font-lock-type-face)
                     ("'Name'" 1 font-lock-string-face)
                     ("$'name={{ input.name }}'" 1 font-lock-string-face)
                     ("true" 0 font-lock-constant-face)
                     ("null" 0 font-lock-constant-face)
                     ("0" 0 font-lock-constant-face)
                     ("for" 0 font-lock-keyword-face)
                     ("example.web" 0 font-lock-function-name-face)
                     ("tags.env" 0 font-lock-property-name-face)
                     ("input.count" 0 font-lock-builtin-face)))
      (unobin-test-face-at (nth 0 check) (nth 1 check) (nth 2 check)))))
