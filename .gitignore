# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, build with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out
# ubtest golden files end in .ub.out and must be tracked.
!*.ub.out

_output/
dist/
site/
.venv-docs/
docs/reference/

# Per-deployment runtime state generated when running an example.
.unobin/
