call-plus-string:    format('%s-%s', input.region, input.name) + '-suffix'
nested-calls:        lib.index-by(format('%s', input.x), 'name')
call-as-operand:     count(input.items) > 0 && input.enabled
arith-with-inputs:   (input.size + 1) * 2
deep-comparison:     input.region == 'us-east-1' || input.region == 'us-west-2'
indexed-in-arith:    input.tags['Name'] + '-x'
arr-of-exprs:        [1 + 1, 2 * 2, format('%d', 3), input.x]
obj-of-exprs: {
  computed: input.x + 1,
  negated:  !input.flag,
  call:     format('%s', input.x),
  guarded:  input.x > 0 && input.x < 100,
}
deep-paren-mix:      ((input.a + 1) * (input.b - 2)) / (input.c + 3)
call-in-call-in-call: outer(middle(inner('deep')), 1)
ternary-like:        input.x > 0 && (input.x < 10 || input.x > 100)
mixed-precedence:    a + b * c == d - e / f && g
unary-on-call:       !lib.is-valid(input.x)
unary-on-paren:      -(input.x + input.y)
chain-with-calls:    a + format('%s', x) + b
call-with-arr-arg:   build([1, 2, 3], input.opts)
call-with-obj-arg:   merge({a: 1, b: 2}, input.extra)
double-indexed:      data-source.x['outer']['inner'].field
