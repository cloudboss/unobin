no-args:        range()
one-arg:         range(3)
multi-arg:       format('%s-%s', input.region, input.name)
nested-calls:    format('%s', b64-encode('plaintext'))
library-call:     lib.index-by(input.items, 'name')
library-no-args:  lib.now()
call-as-arg:     outer(inner('x'), 1)
trailing-comma:  format('%s', input.x,)
