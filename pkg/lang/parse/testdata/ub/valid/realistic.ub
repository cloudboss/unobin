description: 'Production cluster deployment'

inputs: {
  region: {
    type:        string
    description: 'AWS region'
  }
  cluster-name: {
    type:    string
    pattern: '^[a-z][a-z0-9-]{0,30}$'
  }
  size: {
    type:    integer
    minimum: 1
    maximum: 100
  }
  use-spot: {
    type: boolean
  }
  tags: {
    type: object
  }
}

constraints: [
  { kind: required-together, fields: [input.vpc-id, input.subnet-ids] },
]

imports: {
  aws: 'github.com/cloudboss/unobin-libraries/aws'
  net: 'github.com/me/libraries/network'
}

outputs: {
  region: { value: 'us-east-1' }
}

notes: '''|
  Multi-line notes preserve their content with the leading
  indent stripped to the closing-quote column.
  '''
