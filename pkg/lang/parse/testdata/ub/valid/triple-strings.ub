single: '''hello world'''

literal-clip: '''|
  one
  two
  '''

literal-strip: '''|-
  one
  two
  '''

folded-clip: '''>
  one two three
  '''

folded-paragraphs: '''>
  first paragraph
  continues here.

  second paragraph
  also continues.
  '''

folded-more-indented: '''>
  prose paragraph
  that folds normally.

  followed by:
    item one
    item two
    item three

  back to folded prose
  that continues here.
  '''

folded-strip: '''>-
  one two three
  '''

joined-clip: '''\
  https://example.com/
  api/v1/users/12345
  '''

joined-strip: '''\-
  arn:aws:s3:::very-long-bucket-name/
  some/key/with/a/long/prefix/
  and-a-filename.tar.gz
  '''

joined-skips-blanks: '''\-
  first

  second
  '''

embedded-triple-quote: '''|
  before '''mid''' after
  '''

trailing-whitespace-trim: '''|
  one
  two
  '''
