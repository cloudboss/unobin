description: 'Production cluster deployment'

inputs: {
  region: {
    type:        string
    description: 'AWS region'
  }
  cluster-name: {
    type:    string
    pattern: '^[a-z][a-z0-9-]{0,30}$'
  }
  size: {
    type:    integer
    minimum: 1
    maximum: 100
  }
  use-spot: {
    type: boolean
  }
  tags: {
    type: object
  }
}

constraints: [
  { kind: required-together, fields: [vpc-id, subnet-ids] },
]

imports: {
  aws: 'github.com/cloudboss/unobin-modules/aws@v0.5.0'
  net: 'github.com/me/modules/network@v1.2.3'
}

outputs: {
  region: { value: 'us-east-1' }
}

notes: `|
  Multi-line notes preserve their content with the leading
  indent stripped to the closing-backtick column.
  `
