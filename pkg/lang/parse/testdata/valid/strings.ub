simple:        'hello'
empty:         ''
with-spaces:   'one two three'
with-quote:    'it\'s here'
with-backslash: 'a\\b'
with-newline:  'line1\nline2'
with-tab:      'col1\tcol2'
with-cr:       'r\rn'
with-nul:      'a\0b'
