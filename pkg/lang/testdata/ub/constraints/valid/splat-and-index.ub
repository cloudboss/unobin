constraints: [
  { kind: exactly-one-of,     fields: [input.replicas[*].inline, input.replicas[*].from-file] },
  { kind: required-together,  fields: [input.listeners[0].cert, input.listeners[0].key] },
  { kind: required-with,      fields: [input.replicas[*].tls, input.ca-cert] },
  { kind: at-least-one-of,    fields: [input.config.replicas[*].a, input.config.replicas[*].b] },
]
