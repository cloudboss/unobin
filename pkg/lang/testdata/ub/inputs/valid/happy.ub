inputs: {
  region: {
    type:        string
    description: 'AWS region'
    pattern:     '^[a-z]+'
  }
  size: {
    type:    integer
    default: 3
    minimum: 1
    maximum: 100
  }
  subnets: {
    type:      list(string)
    min-items: 1
  }
  tags: {
    type:        optional(map(string))
    default:     {}
    description: 'Resource tags'
    @sensitive:  true
  }
}
