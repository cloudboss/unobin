}
arbitrary-keys: {
  '': 'empty key'
  ' leading space': 1
  'has spaces in middle': 2
  'with.dots': 3
  'with/slashes/path': 4
  'with-dashes-and_underscores': 5
  'starts-with-digit-1': 6
