  'with"double"quotes': 9
  'escaped \'apostrophe\'': 10
  'unicode-cafe': 11
  'true': 'not a bool'
}
all-kinds-of-values: {
  '1': 1
  '1a': [1]
  '1b': [{'a': 'A'}]
  '1c': [[] {}]
  one: {'a': 'A' 'b': 'B'}
  two: {
                      #   _____
    'a': 100 'b': 200 # nested objects with inline comments
                      #
    'c': 300
  }
  '2': 2
  '2a': 2.0
  '2b': 0.2
  true-key: false
  false-key: true
  'true': false
  'false': true
}
