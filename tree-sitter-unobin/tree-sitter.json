{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "unobin",
      "camelcase": "Unobin",
      "title": "Unobin",
      "scope": "source.unobin",
      "file-types": [
        "ub"
      ],
      "injection-regex": "^unobin$",
      "class-name": "TreeSitterUnobin"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Tree-sitter grammar for Unobin",
    "authors": [
      {
        "name": "Joseph Wright",
        "email": "rjosephwright@gmail.com"
      }
    ],
    "links": {
      "repository": "https://github.com/cloudboss/unobin"
    }
  },
  "bindings": {
    "c": true,
    "go": false,
    "node": false,
    "python": false,
    "rust": false,
    "swift": false,
    "zig": false
  }
}
