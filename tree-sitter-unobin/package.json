{
  "name": "tree-sitter-unobin",
  "version": "0.1.0",
  "description": "Tree-sitter grammar for Unobin",
  "main": "grammar.js",
  "license": "MIT",
  "scripts": {
    "generate": "npm exec --package=tree-sitter-cli@0.26.9 -- tree-sitter generate",
    "compile": "npm exec --package=tree-sitter-cli@0.26.9 -- tree-sitter build -o src/libtree-sitter-unobin.so",
    "test": "npm exec --package=tree-sitter-cli@0.26.9 -- tree-sitter test"
  },
  "devDependencies": {
    "tree-sitter-cli": "0.26.9"
  },
  "tree-sitter": [
    {
      "scope": "source.unobin",
      "file-types": [
        "ub"
      ]
    }
  ]
}
