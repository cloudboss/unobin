manifest: {
  requires: {
    'github.com/cloudboss/unobin-libraries-scratch': {
      version: 'v0.8.0'
    }
    'github.com/cloudboss/unobin-library-std': {
      version:  'v0.2.0'
      indirect: true
    }
  }
  replace: {
    'github.com/cloudboss/unobin':                   '../..'
    'github.com/cloudboss/unobin-libraries-scratch': './scratch'
  }
}
