hello: resource {
  description: 'Writes a hello file at the chosen path.'

  inputs: {
    message: { type: string }
    path:    { type: string }
  }

  imports: { std: 'github.com/cloudboss/unobin-library-std' }

  resources: {
    hello-file: std.fs-file {
      path:    var.path
      content: var.message
    }
  }

  outputs: {
    path:   { value: resource.hello-file.path }
    size:   { value: resource.hello-file.size }
    sha256: { value: resource.hello-file.sha256 }
  }
}
