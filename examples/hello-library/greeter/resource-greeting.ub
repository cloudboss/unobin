description: 'Writes a greeting file at the chosen path.'

inputs: { message: { type: string }, path: { type: string } }

imports: { std: 'github.com/cloudboss/unobin-library-std' }

resources: { std: { fs-file: { this: { path: var.path, content: var.message } } } }

outputs: {
  path:   { value: resource.std.fs-file.this.path }
  size:   { value: resource.std.fs-file.this.size }
  sha256: { value: resource.std.fs-file.this.sha256 }
}
