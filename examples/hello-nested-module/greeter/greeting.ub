description: 'Greets by delegating the file write to the remote helloer module.'

inputs: { message: { type: string }, path: { type: string } }

imports: { helloer: 'github.com/cloudboss/unobin-modules-scratch//ub/helloer@v0.1.0' }

resources: { helloer: { hello: { file: { message: var.message, path: var.path } } } }

outputs: {
  path:   { value: resource.helloer.hello.file.path }
  size:   { value: resource.helloer.hello.file.size }
  sha256: { value: resource.helloer.hello.file.sha256 }
}
