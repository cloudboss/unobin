description: 'Hello-world stack that uses nested UB modules.'

inputs: {
  message: {
    type:        string
    description: 'Text to write to the greeting file'
  }
  path: {
    type:        string
    description: 'Filesystem path for the greeting file'
  }
}

imports: {
  core:    'github.com/cloudboss/unobin//pkg/modules/core@v0.1.0'
  greeter: './greeter'
}

resources: {
  greeter: {
    greeting: {
      welcome: {
        message: var.message
        path:    var.path
      }
    }
  }
}

outputs: {
  greeting-path:   resource.greeter.greeting.welcome.path
  greeting-size:   resource.greeter.greeting.welcome.size
  greeting-sha256: resource.greeter.greeting.welcome.sha256
}
