description: 'A thin wrapper around greet.say.'

inputs: {
  message: {
    type:        string
    description: 'Text passed to greet.say'
  }
}

imports: {
  greet: 'github.com/cloudboss/unobin//examples/configurations/greet@v0.1.0'
}

actions: {
  greet: {
    say: {
      this: {
        message: var.message
      }
    }
  }
}

outputs: {
  output: { value: action.greet.say.this.output }
}
