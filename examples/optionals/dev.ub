stack: {
  factory: {
    inputs: {
      base-path: '/tmp'
      name:      'world'
      labels:    { motd: 'have a nice day', team: 'platform' }
      upstreams: [{ host: 'a.internal', port: 8080 }, { host: 'b.internal' }]
    }
  }

  state: local {
    path: '.unobin/state'
  }

  encryption: noop {}
}
